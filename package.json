{
    "name": "chordproject-parser-fork",
    "version": "1.0.0",
    "main": "dist/chordproject-parser.bundle.js",
    "typings": "types/index.d.ts",
    "type": "module",
    "files": [
        "dist",
        "types",
        "src/style.css"
    ],
    "description": "Fork TypeScript library for parsing and formatting ChordPro songs.",
    "keywords": [
        "chordpro",
        "chordproject",
        "parser",
        "chord",
        "guitar"
    ],
    "scripts": {
        "start": "vite demo",
        "clean": "rimraf dist",
        "build": "bun run clean && tsup src/index.ts --format esm,cjs --dts --clean",
        "release": "bun run build && bun publish",
        "test": "bunx jest --runInBand --detectOpenHandles --colors --verbose --reporters=default",
        "test:ci": "bunx jest --ci --runInBand --silent --colors --coverage"
    },
    "devDependencies": {
        "@types/node": "25.9.3",
        "jest": "30.4.2",
        "rimraf": "6.1.3",
        "ts-jest": "29.4.11",
        "tsup": "8.5.1",
        "typescript": "6.0.3",
        "vite": "8.0.16"
    }
}
